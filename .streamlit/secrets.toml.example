# Copy into Streamlit Cloud: App → Settings → Secrets (never commit real keys).
#
# News backfill (src/news_agent.py) uses OpenRouter with the OpenAI Python SDK:
#   OPENROUTER_API_KEY = "sk-or-..."
# Optional:
#   OPENROUTER_MODEL = "meta-llama/llama-3.3-70b-instruct"
#
# If you add Claude-based code later:
#   ANTHROPIC_API_KEY = "sk-ant-..."
